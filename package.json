{
  "name": "uplim-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "UPLim monorepo",
  "scripts": {
    "build": "tsc -b packages/frontend packages/runtime packages/compiler-js packages/tooling packages/core packages/cli packages/lsp apps/vscode-extension",
    "build:frontend": "tsc -b packages/frontend",
    "build:runtime": "tsc -b packages/runtime",
    "build:compiler-js": "tsc -b packages/compiler-js",
    "build:tooling": "tsc -b packages/tooling",
    "build:core": "tsc -b packages/core",
    "build:cli": "tsc -b packages/cli",
    "build:lsp": "tsc -b packages/lsp",
    "build:extension": "tsc -b apps/vscode-extension",
    "dev": "tsx packages/cli/src/cli.ts",
    "analyze": "tsx packages/cli/src/cli.ts analyze",
    "test": "python3 test_uplim.py",
    "smoke:facade": "tsx tests/facade-smoke.ts",
    "smoke:manifest": "tsx tests/manifest-smoke.ts",
    "smoke:project-build": "tsx tests/project-build-smoke.ts",
    "smoke:project-serve": "tsx tests/project-serve-smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
