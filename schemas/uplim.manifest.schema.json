{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uplim.org/schemas/uplim.manifest.schema.json",
  "title": "UPLim Manifest Schema",
  "description": "Canonical semantic schema for uplim.toml. The TOML document maps to this JSON structure for validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package",
    "build",
    "capabilities"
  ],
  "properties": {
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "edition"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
        },
        "edition": {
          "type": "string",
          "enum": [
            "v1"
          ]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry",
        "profile",
        "output"
      ],
      "properties": {
        "entry": {
          "type": "string",
          "pattern": ".*\\.upl$"
        },
        "profile": {
          "type": "string",
          "enum": [
            "wasm-component",
            "wasm-module-dev",
            "js-interop",
            "native-llvm"
          ]
        },
        "output": {
          "type": "string",
          "minLength": 1
        },
        "app_root": {
          "type": "string"
        },
        "module_roots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "test_roots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesystem_read": { "type": "boolean" },
        "filesystem_write": { "type": "boolean" },
        "network_client": { "type": "boolean" },
        "network_server": { "type": "boolean" },
        "clock_wall": { "type": "boolean" },
        "clock_monotonic": { "type": "boolean" },
        "env_read": { "type": "boolean" },
        "process_spawn": { "type": "boolean" },
        "ai_remote": { "type": "boolean" },
        "ai_local": { "type": "boolean" },
        "ai_embedding": { "type": "boolean" },
        "ai_tool_call": { "type": "boolean" },
        "mcp_client": { "type": "boolean" }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "ollama",
            "custom"
          ]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "structured",
            "text",
            "tooling"
          ]
        },
        "allow_tool_calls": {
          "type": "boolean"
        },
        "allow_mcp": {
          "type": "boolean"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "capabilities": {
            "properties": {
              "ai_remote": { "const": true }
            },
            "required": [
              "ai_remote"
            ]
          }
        }
      },
      "then": {
        "required": [
          "ai"
        ],
        "properties": {
          "capabilities": {
            "properties": {
              "network_client": { "const": true }
            },
            "required": [
              "network_client"
            ]
          },
          "ai": {
            "required": [
              "provider",
              "model",
              "mode"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "capabilities": {
            "properties": {
              "ai_tool_call": { "const": true }
            },
            "required": [
              "ai_tool_call"
            ]
          }
        }
      },
      "then": {
        "required": [
          "ai"
        ],
        "properties": {
          "ai": {
            "properties": {
              "allow_tool_calls": { "const": true }
            },
            "required": [
              "allow_tool_calls"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "capabilities": {
            "properties": {
              "mcp_client": { "const": true }
            },
            "required": [
              "mcp_client"
            ]
          }
        }
      },
      "then": {
        "required": [
          "ai"
        ],
        "properties": {
          "ai": {
            "properties": {
              "allow_mcp": { "const": true }
            },
            "required": [
              "allow_mcp"
            ]
          }
        }
      }
    }
  ]
}
